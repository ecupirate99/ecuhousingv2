{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python"
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/chat",
            "destination": "/main.py"
        },
        {
            "source": "/upload",
            "destination": "/main.py"
        },
        {
            "source": "/health",
            "destination": "/main.py"
        },
        {
            "source": "/",
            "destination": "/static/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/static/$1"
        }
    ]
}